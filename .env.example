# ═══════════════════════════════════════════════════════════════
#  ClawOps — Production Environment Variables
#  Copy to .env and replace all placeholder values before starting
# ═══════════════════════════════════════════════════════════════

# ── Domain ───────────────────────────────────────────────────
# Your domain name (e.g. clawops.example.com) or server IP
# Nginx uses this for server_name and CORS origin
DOMAIN=example.com

# ── Ports (host-side) ───────────────────────────────────────
# Nginx listens on 80/443 — backend and frontend are internal only
HTTP_PORT=80
HTTPS_PORT=443

# ── Database ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=openclaw
DB_USERNAME=openclaw
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── Application ──────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ── Encryption (generate: openssl rand -base64 32) ──────────
MASTER_ENCRYPTION_KEY=9/SQsa8ut8/8WOV+aDf3ksYa22BN82Imo8YsgaP3Byk=

# ── JWT (generate: openssl rand -base64 64) ─────────────────
JWT_SECRET=prsNh68fvGjOIbFvmi46a8itmhL/lh2f6HYv2X6BT6X9f4xHuCtyWBpkxdsy+IjJ8tqpkxE2KotPVDFLkamXgg==
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ── Admin Bootstrap (created on first startup if no users) ──
ADMIN_EMAIL=admin@openclaw.dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Swagger UI (false in production) ────────────────────────
SWAGGER_ENABLED=false

# ── Login Security ──────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# ── CORS (frontend origin — must match DOMAIN) ─────────────
CORS_ALLOWED_ORIGINS=https://${DOMAIN}
CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,Accept,Origin
CORS_EXPOSE_HEADERS=
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ── SSH ─────────────────────────────────────────────────────
SSH_STRICT_HOST_KEY_CHECKING=true

# ── Frontend ────────────────────────────────────────────────
FE_PORT=3000
NEXT_PUBLIC_API_ORIGIN=https://${DOMAIN}

# ── Monitoring ──────────────────────────────────────────────
MONITORING_SCHEDULER_INTERVAL=30000
MONITORING_CHECK_DEFAULT_INTERVAL=60
MONITORING_CHECK_TIMEOUT=30
MONITORING_METRICS_RETENTION_DAYS=7